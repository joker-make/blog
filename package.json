{
  "name": "joker-make-blog",
  "version": "1.0.0",
  "private": true,
  "description": "Hexo static blog for GitHub Pages.",
  "hexo": {
    "version": "7.3.0"
  },
  "scripts": {
    "server": "node ./node_modules/hexo-cli/bin/hexo server",
    "build": "node ./node_modules/hexo-cli/bin/hexo clean && node ./node_modules/hexo-cli/bin/hexo generate",
    "new": "node ./node_modules/hexo-cli/bin/hexo new post"
  },
  "dependencies": {
    "hexo": "^7.3.0",
    "hexo-cli": "^4.3.2",
    "hexo-generator-archive": "^2.0.0",
    "hexo-generator-category": "^2.0.0",
    "hexo-generator-tag": "^2.0.0",
    "hexo-renderer-ejs": "^2.0.0",
    "hexo-renderer-marked": "^7.0.1",
    "hexo-renderer-stylus": "^3.0.1",
    "hexo-server": "^3.0.0"
  }
}

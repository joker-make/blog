<% const posts = site.posts.sort('-date').toArray(); %>

<div class="home-page">
  <section class="hero glass-card">
    <div class="hero-badge">信号上线 · STATIC 版本</div>
    <h1>欢迎进入我的技术主控台</h1>
    <p>记录学习轨迹、沉淀工程经验、输出可复用的技术资产。</p>
    <div class="hero-actions">
      <a class="btn btn-primary" href="<%- url_for('/articles/') %>">浏览文章</a>
      <a class="btn btn-plain" href="<%- url_for('/about/') %>">认识作者</a>
    </div>
    <div class="hero-grid">
      <div class="hero-card">
        <span class="label">当前版本</span>
        <h3>Hexo + GitHub Pages</h3>
        <p>零服务器成本的静态博客部署。</p>
      </div>
      <div class="hero-card">
        <span class="label">写作方向</span>
        <h3>架构 · 性能 · 工程实践</h3>
        <p>用结构化文档沉淀高质量输出。</p>
      </div>
      <div class="hero-card">
        <span class="label">维护方式</span>
        <h3>Markdown 驱动</h3>
        <p>推送到 main 分支后自动发布。</p>
      </div>
    </div>
  </section>

  <section class="section glass-card">
    <div class="section-header">
      <h2>最新文章</h2>
      <a class="text-link" href="<%- url_for('/articles/') %>">进入文章中心</a>
    </div>
    <% if (posts.length) { %>
      <div class="article-list">
        <% posts.slice(0, 5).forEach(function(post) { %>
          <a class="article-row" href="<%- url_for(post.path) %>">
            <span><%= post.title %></span>
            <time><%= date(post.date, 'YYYY-MM-DD') %></time>
          </a>
        <% }) %>
      </div>
    <% } else { %>
      <div class="empty-state">暂无文章，先用 Markdown 写下第一篇吧。</div>
    <% } %>
  </section>
</div>

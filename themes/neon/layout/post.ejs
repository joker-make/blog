<article class="post-shell">
  <section class="post-card glass-card">
    <header class="post-header">
      <a class="text-link" href="<%- url_for('/articles/') %>">返回文章中心</a>
      <h1><%= page.title %></h1>
      <time><%= date(page.date, 'YYYY-MM-DD') %></time>
    </header>
    <div class="content">
      <%- page.content %>
    </div>
  </section>
</article>
